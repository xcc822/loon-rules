[Rewrite]
# 常见广告接口关键词拦截（通用但有误伤概率，放在配置尾部更稳）
^https?:\/\/.*\b(ad|ads|advert|advertise|advertisement|splash|startup|launchad|openad|screenad|top_notice|promotion)\b.* - reject
^https?:\/\/.*\b(track|tracking|analytics|stat|report|reporting|telemetry)\b.* - reject
^https?:\/\/.*\b(appsflyer|adjust|kochava|branch|tenjin|singular)\b.* - reject
